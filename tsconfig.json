{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@fresh-schedules/types": ["packages/types/src/index.ts"]
    },
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/*", "apps/web/src/*"],
      "@fresh-schedules/types": ["packages/types/src/index.ts"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "types/**/*.d.ts",
    "apps/**/*",
    "functions/**/*",
    "packages/**/*",
    "services/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "tests/**",
    "scripts",
    "scripts/**",
    "tests/e2e/**",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "types/firebase-admin.d.ts"
  ]

}
